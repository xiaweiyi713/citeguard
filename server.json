{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.xiaweiyi713/citeguard",
  "description": "Falsification-first citation auditor: existence, metadata, and claim-support checks via MCP.",
  "repository": {
    "url": "https://github.com/xiaweiyi713/citeguard",
    "source": "github"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "citationguard",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [],
      "environmentVariables": [
        {
          "name": "CITEGUARD_SOURCES",
          "description": "Comma-separated scholarly sources (default: openalex,crossref,arxiv).",
          "isRequired": false
        },
        {
          "name": "CITEGUARD_MAILTO",
          "description": "Contact email for polite OpenAlex/Crossref access.",
          "isRequired": false
        }
      ]
    }
  ]
}
